# ====================================================================
# StudyFlow - Variables d'environnement
# Copier ce fichier en `.env` et le remplir.
# IMPORTANT : `.env` est ignoré par Git.
# ====================================================================

# ---- Profil Spring (dev / prod) ----
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ---- PostgreSQL (Supabase) ----
SUPABASE_DB_URL=jdbc:postgresql://<host>:5432/<database>
SUPABASE_DB_USERNAME=<database-user>
SUPABASE_DB_PASSWORD=<database-password>

# ---- Supabase (Angular - frontend) ----
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-key>
SUPABASE_SECRET_KEY=<supabase-secret-key>

# ---- MongoDB Atlas ----
MONGO_URI=mongodb://localhost:27017/studyflow
MONGO_DATABASE=studyflow

# ---- JWT ----
# Générer avec : openssl rand -base64 64
JWT_SECRET=change_me_change_me_change_me_change_me_64_chars_minimum
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ---- CORS (frontend Angular) ----
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ---- SMTP Gmail (envoi reel des emails de reset) ----
# Optionnel : si vide, les emails sont logges dans la console du backend.
# Pour Gmail : creer un App Password sur https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre@gmail.com
MAIL_PASSWORD=<mail-app-password>
MAIL_FROM=votre@gmail.com

# ---- Google OAuth2 (optionnel) ----
# Si vide, le bouton "Continue with Google" reste actif mais retournera une erreur.
# Creer un OAuth Client sur https://console.cloud.google.com -> APIs & Services -> Credentials
# Authorized redirect URIs: http://localhost:8080/login/oauth2/code/google
# Authorized JavaScript origins: http://localhost:4200
# GOOGLE_CLIENT_ID=votre_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=<google-client-secret>
